# .env.local.example — copy to .env.local and fill in
# Vite bakes these into the JS bundle at build time (npm run build).
# After editing, re-run: npm run build

# REST API base URL, no trailing slash (e.g. http://localhost:8084)
VITE_API_BASE_URL=

# API key — must match api_key in tools/book_service/config/configuration.json
VITE_API_KEY=

# Base URL for static book cover images, no trailing slash
VITE_RESOURCE_BASE_URL=

# AI Chat: base URL for Ollama-compatible API, no trailing slash (optional)
VITE_OLLAMA_BASE_URL=

# AI Chat: model name (e.g. openai/gpt-oss-20b)
VITE_OLLAMA_MODEL=

# AI Chat: bearer token for Ollama endpoint (leave blank if unauthenticated)
VITE_OLLAMA_API_KEY=
